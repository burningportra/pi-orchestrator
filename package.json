{
  "name": "pi-orchestrator",
  "version": "0.8.0",
  "description": "Multi-agent orchestrator for pi — deep planning, parallel execution, guided review gates, compound memory. Based on the Agentic Coding Flywheel.",
  "repository": {
    "type": "git",
    "url": "https://github.com/burningportra/pi-orchestrator.git"
  },
  "homepage": "https://github.com/burningportra/pi-orchestrator",
  "keywords": [
    "pi",
    "orchestrator",
    "multi-agent",
    "flywheel",
    "coding-agent",
    "parallel-execution",
    "sophia"
  ],
  "files": [
    "src/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
