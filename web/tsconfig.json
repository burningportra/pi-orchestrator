{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/client",
    "rootDir": "client/src",
    "declaration": false,
    "noEmit": true
  },
  "include": ["client/src"]
}
